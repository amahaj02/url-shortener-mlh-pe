FLASK_DEBUG=true
TESTING=false
AUTO_CREATE_TABLES=true
HOST=0.0.0.0
PORT=5000
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Pool is per Gunicorn worker process. Keep (pods × workers × pool size) under Postgres max (e.g. 22).
DATABASE_MAX_CONNECTIONS=3
DATABASE_POOL_RESERVED_CONNECTIONS=1
DATABASE_STALE_TIMEOUT_SECONDS=300
DATABASE_POOL_WAIT_TIMEOUT_SECONDS=10

WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=2
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
# "-" = stdout/stderr (good for kubectl logs). Optional: file path.
GUNICORN_ACCESS_LOG=-
GUNICORN_ERROR_LOG=-
GUNICORN_LOG_LEVEL=info
WAITRESS_THREADS=8
