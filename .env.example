FLASK_DEBUG=true
TESTING=false
AUTO_CREATE_TABLES=true

# App logging (root handler). DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: log GET /urls query args at INFO (e.g. troubleshooting pagination tests)
PE_DEBUG_LIST_URLS=false

# Event pipeline: bounded queue + batch inserts (skipped when TESTING=true uses sync writes)
EVENT_QUEUE_MAX=5000
EVENT_BATCH_SIZE=100
EVENT_FLUSH_INTERVAL_SEC=0.15
HOST=0.0.0.0
PORT=3000
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Managed Postgres (e.g. DigitalOcean port 25061) requires TLS — set require or verify-full.
# DATABASE_SSLMODE=require
#
# Connection pooler (PgBouncer / managed “pool” endpoint): point DATABASE_HOST (and port if
# different) at the pool hostname from your provider’s dashboard — not the “direct” DB host.
# The app still uses Peewee’s per-worker pool; the pooler multiplexes many client connections
# onto fewer Postgres server connections. After switching, you can often raise DATABASE_MAX_CONNECTIONS
# per worker within the pooler’s client limit (see provider docs); keep Postgres max_connections in mind.
# Optional: seconds to wait when opening a connection (default is libpq default).
# DATABASE_CONNECT_TIMEOUT=10
# Per-worker Peewee pool (each Gunicorn worker is a process with its own pool).
# Peak app conns ≈ maxReplicas × WEB_CONCURRENCY × DATABASE_MAX_CONNECTIONS (e.g. 3×1×48=144 with a 197 max_connections cluster).
DATABASE_MAX_CONNECTIONS=48
# Connections held back per worker from Gunicorn thread cap (0 = threads may use full pool).
DATABASE_POOL_RESERVED_CONNECTIONS=0
DATABASE_STALE_TIMEOUT_SECONDS=300
DATABASE_POOL_WAIT_TIMEOUT_SECONDS=10

WEB_CONCURRENCY=1
# Gunicorn gthread: threads per worker. Peewee still uses DATABASE_MAX_CONNECTIONS pooled conns
# per worker (shared by all threads). By default threads are capped to that pool size.
# Set to false to allow GUNICORN_THREADS > pool size (shared pool; good with Redis-first redirects).
GUNICORN_THREADS_CAP_TO_POOL=false
# HTTP threads per worker; can exceed DATABASE_MAX_CONNECTIONS when cap is false (pool shared).
GUNICORN_THREADS=64
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=2
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
# Access log: leave unset (or none/off) so only app.http logs each request — avoids duplicating Gunicorn + Flask lines.
# Set to "-" if you also want Gunicorn's access line (e.g. dur_us from the worker).
GUNICORN_ERROR_LOG=-
GUNICORN_LOG_LEVEL=info

# Optional: Redis / Valkey short-link cache. Omit REDIS_URL and REDIS_HOST to disable.
# Eviction: configure maxmemory-policy on the server (e.g. allkeys-lru); not an app variable.
# Local: redis://127.0.0.1:6379/0
# DigitalOcean managed Valkey (TLS, port often 25061): use rediss:// and username "default"
# REDIS_URL=rediss://default:YOUR_PASSWORD@your-cluster.db.ondigitalocean.com:25061
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_CACHE_TTL_SECONDS=86400
